{
  "manifest_version": 3,
  "name": "VaultID for Gmail",
  "version": "1.0",
  "description": "The Crowdsourced Identity Layer for the Modern Inbox.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["inboxsdk.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}